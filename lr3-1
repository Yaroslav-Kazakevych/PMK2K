#include "project.h"

/* Масиви вказівників на функції PSoC Creator для роботи з пінами */
static void (*COLUMN_x_SetDriveMode[3])(uint8_t mode) = {
    COLUMN_0_SetDriveMode, COLUMN_1_SetDriveMode, COLUMN_2_SetDriveMode
};
static void (*COLUMN_x_Write[3])(uint8_t value) = {
    COLUMN_0_Write, COLUMN_1_Write, COLUMN_2_Write
};
static uint8 (*ROW_x_Read[4])() = {
    ROW_0_Read, ROW_1_Read, ROW_2_Read, ROW_3_Read
};

/* Масив для збереження станів кнопок: 0 - натиснуто, 1 - відпущено */
static uint8_t keys[4][3];

/* Функція ініціалізації: переводить стовпці у режим High Impedance (вимкнено) */
static void initMatrix() {
    for(int column_index = 0; column_index < 3; column_index++) {
        COLUMN_x_SetDriveMode[column_index](COLUMN_0_DM_DIG_HIZ);
    }
}

/* Функція сканування матриці: по черзі подає 0 на стовпці і зчитує рядки */
static void readMatrix() {
    uint8_t row_counter = 4;
    uint8_t column_counter = 3;
    for(int column_index = 0; column_index < column_counter; column_index++) {
        COLUMN_x_SetDriveMode[column_index](COLUMN_0_DM_STRONG);
        COLUMN_x_Write[column_index](0);
        for(int row_index = 0; row_index < row_counter; row_index++) {
            keys[row_index][column_index] = ROW_x_Read[row_index]();
        }
        COLUMN_x_SetDriveMode[column_index](COLUMN_0_DM_DIG_HIZ);
    }
}

int main(void)
{
    CyGlobalIntEnable; /* Увімкнення глобальних переривань */
    SW_Tx_UART_Start();
    initMatrix();

    /* На початку горить White (для спільного анода 0 - це увімкнення) */
    LED_R_Write(0); LED_G_Write(0); LED_B_Write(0);
    
    /* Змінна-прапорець, щоб знати, чи було перше натискання */
    uint8_t first_press_done = 0; 

    for(;;)
    {
        readMatrix(); /* Оновлюємо стан кнопок */
        uint8_t any_pressed = 0; /* Прапорець: чи натиснута зараз хоч якась кнопка */

        /* Перевіряємо умови (if / else) згідно з таблицею 1 */
        if(keys[0][0] == 0 || keys[2][0] == 0) { // Red: 1 або 7
            LED_R_Write(0); LED_G_Write(1); LED_B_Write(1);
            any_pressed = 1; first_press_done = 1;
        }
        else if(keys[0][1] == 0 || keys[2][1] == 0) { // Green: 2 або 8
            LED_R_Write(1); LED_G_Write(0); LED_B_Write(1);
            any_pressed = 1; first_press_done = 1;
        }
        else if(keys[0][2] == 0 || keys[2][2] == 0) { // Blue: 3 або 9
            LED_R_Write(1); LED_G_Write(1); LED_B_Write(0);
            any_pressed = 1; first_press_done = 1;
        }
        else if(keys[1][0] == 0 || keys[3][0] == 0) { // Yellow: 4 або *
            LED_R_Write(0); LED_G_Write(0); LED_B_Write(1);
            any_pressed = 1; first_press_done = 1;
        }
        else if(keys[1][1] == 0 || keys[3][1] == 0) { // Purple: 5 або 0
            LED_R_Write(0); LED_G_Write(1); LED_B_Write(0);
            any_pressed = 1; first_press_done = 1;
        }
        else if(keys[1][2] == 0 || keys[3][2] == 0) { // Cyan: 6 або #
            LED_R_Write(1); LED_G_Write(0); LED_B_Write(0);
            any_pressed = 1; first_press_done = 1;
        }

        /* Якщо після першого старту кнопки відпустили (any_pressed == 0) -> вимикаємо (Black) */
        if(any_pressed == 0 && first_press_done == 1) {
            LED_R_Write(1);
            LED_G_Write(1);
            LED_B_Write(1);
        }
    }
}
